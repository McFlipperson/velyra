# Velyra Environment Variables

# AI (Bedrock)
AWS_REGION=us-east-1
VELYRA_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
VELYRA_SYSTEM_PROMPT=          # Optional. Leave empty for default concierge prompt.
VELYRA_MAX_TOKENS=300

# Voice (Polly)
VELYRA_VOICE_ID=Danielle       # AWS Polly Neural voice ID

# Rate Limits
VELYRA_MAX_MESSAGES=50         # Max chat messages per session
VELYRA_SESSION_TIMEOUT_MS=1800000  # 30 min session timeout
